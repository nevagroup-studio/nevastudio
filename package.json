{
  "name": "neva-studio",
  "private": true,
  "version": "0.1.1",
  "description": "NEVA Studio desktop and web app",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:3000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:3000 electron .\"",
    "build": "vite build",
    "build:web": "vite build",
    "build:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File electron\\build-installer.ps1",
    "build:desktop:portable": "powershell -NoProfile -ExecutionPolicy Bypass -File electron\\build-portable.ps1",
    "release:github": "powershell -NoProfile -ExecutionPolicy Bypass -File electron\\publish-github-release.ps1",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "@tailwindcss/vite": "^4.2.0",
    "electron-updater": "^6.8.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.nevastudio.desktop",
    "productName": "NEVA Studio",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "${env.GH_OWNER}",
        "repo": "${env.GH_REPO}",
        "releaseType": "release"
      }
    ],
    "artifactName": "NEVA-Studio-${version}-${arch}.${ext}",
    "nsis": {
      "artifactName": "NEVA-Studio-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "NEVA-Studio-Portable-${version}.${ext}"
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
